OPENAI_API_KEY=your_openai_api_key_here
JUDGE_MODEL=gpt-4.1-mini
JUDGE_TIMEOUT_MS=7000
CORS_ORIGINS=http://localhost:5173
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=jeopardy-evals
INTERNAL_API_TOKEN=choose_a_long_random_string
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Local defaults (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=jeopardy
DB_USER=jeopardy
DB_PASSWORD=jeopardy
DB_SSLMODE=disable

# Railway/production: prefer a single URL
# DATABASE_URL=postgresql://user:pass@host:port/dbname?sslmode=require
